# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# =========================================================================
# CeFi Platform - Environment Configuration Blueprint
# =========================================================================

# General Application Port & Host
PORT=3000
NODE_ENV="development"
CLIENT_URL="http://localhost:3000"

# JWT Authentication Configuration
JWT_SECRET="super-secret-key-change-in-production-cefi"
JWT_REFRESH_SECRET="super-refresh-secret-key-change-in-production-cefi"

# Relational Database URL (Relational fallback connection string if requested)
DATABASE_URL="postgresql://user:password@localhost:5432/db"

# Cloud SQL Integration Variables (Rely on these for the Object Method connection pooling)
# Automatically provided in the Cloud Run runtime, or populated locally during testing.
SQL_HOST="/cloudsql/project:region:instance"
SQL_DB_NAME="ai-studio"
SQL_USER="sql_app_user"
SQL_PASSWORD="secure_app_password"

# Schema Management Admin Credentials (Used by Drizzle Kit for database migrations)
SQL_ADMIN_USER="sql_admin_user"
SQL_ADMIN_PASSWORD="secure_admin_password"

# Superadmin Bootstrap Credentials
SUPERADMIN_EMAIL="superadmin@cefi.platform"
SUPERADMIN_PASSWORD="SecureSuperPass123!"

# Email Service Configuration (Resend) — REQUIRED, no defaults.
# EmailService/ResendProvider fail fast at construction time if either is missing.
RESEND_API_KEY="re_your_resend_api_key"
EMAIL_FROM="MetaFirm <noreply@metafirm.app>"

# =========================================================================
# Self-Managed HD Wallet & Blockchain Configurations
# =========================================================================
# Environment mode: 'production', 'sandbox', or 'development' (default: 'development')
BLOCKCHAIN_ENV="sandbox"

# Tatum API key for live networks (Starts with 't-' for testnet / sandbox keys)
TATUM_API_KEY=""

# Optional explicit testnet flag override ('true' or 'false')
IS_TESTNET="true"

# Optional Base URL override for Tatum API (Defaults to https://api.tatum.io)
TATUM_BASE_URL="https://api.tatum.io"

# Custom Token Contract Overrides (Optional; defaults automatically selected based on environment)
USDT_BEP20_CONTRACT=""
USDT_POLYGON_CONTRACT=""
USDT_TRC20_CONTRACT=""

# BIP32/BIP44 Extended Public Keys (xpub/tpub) for address generation
USDT_BEP20_XPUB="xpub..."
USDT_POLYGON_XPUB="xpub..."
USDT_TRC20_XPUB="xpub..."

# BIP32/BIP44 Extended Private Keys (xpriv/tpriv) for secure signing
# WARNING: Keep these strictly secret. Never commit production values.
USDT_BEP20_XPRIV="xprv..."
USDT_POLYGON_XPRIV="xprv..."
USDT_TRC20_XPRIV="xprv..."

# Production Webhook Security HMAC Secret
TATUM_WEBHOOK_SECRET="super-secret-webhook-signing-key"

